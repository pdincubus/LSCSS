---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const themeLayerExample = `@layer theme {
    .product-card {
        border-radius: 1rem;
    }
}`;
---

<DocsLayout
    title="LSCSS Theme Layer"
    description="Theme layer guidance for Layered Semantic CSS."
>
    <section class="site-hero">
        <p class="eyebrow">Theme layer</p>

        <h1>
            Theme adjustments
        </h1>

        <p class="intro">
            The theme layer provides optional brand and visual overrides.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={themeLayerExample} />
    </section>
</DocsLayout>
