---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout
    title="LSCSS Starter Template"
    description="Starter structure for Layered Semantic CSS projects."
>
    <section class="site-hero">
        <p class="eyebrow">Starter template</p>

        <h1>
            Starter structure
        </h1>
    </section>

    <section class="content-block">
<pre><code>css/
    settings/
    base/
    utilities/
    layout/
    components/
    theme/
    legacy/
    hacks/</code></pre>
    </section>

    <section class="content-block">
        <p>
            Each component should live in its own partial and belong to a clear
            layer.
        </p>
    </section>
</DocsLayout>
