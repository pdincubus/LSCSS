---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import CodeExample from '../../../../components/CodeExample.astro';

const scopeExample = `@scope (.product-card) {
    .title {
        margin: 0;
    }

    .price {
        color: var(--colour-accent);
    }
}`;
---

<DocsLayout
    title="Scope Demo"
    description="Demonstrating scoped CSS architecture."
>
    <section class="site-hero">
        <p class="eyebrow">Tool</p>

        <h1>
            Scope demo
        </h1>

        <p class="intro">
            Scoped CSS allows shorter selectors with safer component
            boundaries.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={scopeExample} />
    </section>

    <section class="content-block">
        <article class="example-card">
            <h2 class="title">
                Scoped component example
            </h2>

            <p>
                This example demonstrates semantic structure with reduced
                selector verbosity.
            </p>
        </article>
    </section>
</DocsLayout>
