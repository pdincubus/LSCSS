---
import DocsLayout from '../../layouts/DocsLayout.astro';

const title = 'Core Methodology';
const description = 'The core Layered Semantic CSS methodology: layers, naming, architecture, utilities, theme rules, hacks, tooling, breakpoint organisation, and long-term maintainability.';

const sections = [
    {
        title: 'Layers',
        href: '/layers/',
        description: 'Use explicit cascade layers to control precedence and reduce specificity battles.'
    },
    {
        title: 'Naming',
        href: '/naming/',
        description: 'Use semantic component names, short child classes, modifiers, and state classes.'
    },
    {
        title: 'Modifiers and state',
        href: '/modifiers-and-state/',
        description: 'Separate reusable variants from temporary or conditional UI state.'
    },
    {
        title: 'Architecture',
        href: '/architecture/',
        description: 'Structure CSS files, partials, folders, responsibilities, and media queries in a predictable way.'
    },
    {
        title: 'Utilities',
        href: '/utilities/',
        description: 'Use utilities deliberately, not as a replacement for component architecture.'
    },
    {
        title: 'Theme layer',
        href: '/theme-layer/',
        description: 'Keep visual overrides and brand-level styling isolated from component logic.'
    },
    {
        title: 'Hacks',
        href: '/hacks/',
        description: 'Contain temporary fixes so they do not become permanent architecture.'
    },
    {
        title: 'Tooling',
        href: '/tooling/',
        description: 'Let build tools handle browser support, checks, and repetitive processing work.'
    }
];
---

<DocsLayout
    title={title}
    description={description}
>
    <section class="site-hero">
        <p class="eyebrow">Core methodology</p>

        <h1>
            Core methodology
        </h1>

        <p class="intro">
            LSCSS is built from a small set of practical rules: clear layers,
            semantic naming, shallow selectors, explicit modifiers, state
            classes, isolated hacks, breakpoint-specific media queries, and
            sensible tooling.
        </p>
    </section>

    <nav class="section-nav" aria-label="Core methodology sections">
        <a href="#methodology-sections">Sections</a>
        <a href="#layers-of-protection">Layers of protection</a>
        <a href="#recommended-path">Recommended path</a>
        <a href="/architecture/#media-queries">Media queries</a>
        <a href="/decision-trees/">Decision trees</a>
    </nav>

    <section id="methodology-sections" class="content-block">
        <h2>
            Methodology sections
        </h2>

        <div class="hub-card-grid">
            {
                sections.map((section) => (
                    <article class="hub-card">
                        <h3>
                            <a href={section.href}>{section.title}</a>
                        </h3>

                        <p>
                            {section.description}
                        </p>
                    </article>
                ))
            }
        </div>
    </section>

    <section id="layers-of-protection" class="content-block">
        <h2>
            Layers of protection
        </h2>

        <p>
            These rules are not separate preferences. They work together.
            Each part of the methodology adds protection against a different
            kind of maintenance problem.
        </p>

        <ul>
            <li>Cascade layers protect override order and reduce specificity battles.</li>
            <li>CSS variables protect design consistency and stop random values spreading.</li>
            <li>Custom media queries protect breakpoint clarity and remove magic numbers.</li>
            <li>Scoped child selectors protect component ownership and readability.</li>
            <li>Modifiers protect reusable variant meaning.</li>
            <li>State classes protect interaction clarity and temporary UI behaviour.</li>
            <li>File-size guidance protects cognitive load and long-term maintainability.</li>
        </ul>

        <p>
            None of these rules are complicated on their own. Together they make
            the system more predictable, easier to debug, and much harder to
            accidentally ruin.
        </p>
    </section>

    <section id="recommended-path" class="content-block">
        <h2>
            Recommended path
        </h2>

        <ol>
            <li>Start with layers.</li>
            <li>Move on to naming.</li>
            <li>Understand modifiers and state.</li>
            <li>Review architecture, folder structure, and media query organisation.</li>
            <li>Use utilities, theme rules, hacks, and tooling with intent.</li>
        </ol>
    </section>
</DocsLayout>
