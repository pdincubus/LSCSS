---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeExample from '../../../components/CodeExample.astro';

const widthTransitionExample = `.panel {
    transition: width 0.3s ease;
}`;

const transformTransitionExample = `.panel {
    transition: transform 0.3s ease;
}`;

const isolationExample = `@layer legacy, settings, base, utilities,
layout, components, theme, hacks;

@import './vendor/slider.css' layer(legacy);`;
---

<DocsLayout
    title="Performance Architecture Demos"
    description="Interactive performance-focused CSS architecture demos."
>
    <section class="site-hero">
        <p class="eyebrow">Tool</p>

        <h1>
            Performance architecture demos
        </h1>

        <p class="intro">
            CSS performance is rarely about one selector. It is usually about
            architecture, bundle size, unused code, animation choices, and
            long-term maintainability.
        </p>
    </section>

    <section class="content-block">
        <h2>
            Bundle size comparison
        </h2>

        <form class="tool-panel" data-performance-tool>
            <label for="css-size">
                CSS size in KB
            </label>

            <input
                id="css-size"
                class="tool-input"
                type="range"
                min="10"
                max="500"
                value="120"
                data-css-size
            />

            <output data-css-output>
                120 KB
            </output>
        </form>

        <div class="performance-meter" data-performance-meter>
            <span></span>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Bad architecture vs better architecture
        </h2>

        <div class="performance-grid">
            <article class="performance-card performance-card--bad">
                <h3>
                    Problem
                </h3>

                <ul>
                    <li>large global stylesheet</li>
                    <li>unused component CSS loaded everywhere</li>
                    <li>third-party styles mixed with project styles</li>
                    <li>layout, theme, and hacks in one file</li>
                </ul>
            </article>

            <article class="performance-card performance-card--good">
                <h3>
                    Better
                </h3>

                <ul>
                    <li>CSS grouped by responsibility</li>
                    <li>component partials</li>
                    <li>legacy and third-party CSS isolated</li>
                    <li>clear layer boundaries</li>
                </ul>
            </article>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Animation performance
        </h2>

        <div class="performance-grid">
            <article class="performance-card">
                <h3>
                    Avoid
                </h3>

                <CodeExample code={widthTransitionExample} />
            </article>

            <article class="performance-card">
                <h3>
                    Prefer
                </h3>

                <CodeExample code={transformTransitionExample} />
            </article>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Third-party CSS isolation
        </h2>

        <CodeExample code={isolationExample} />

        <p>
            Third-party CSS should be contained. It should not quietly dominate
            the whole cascade.
        </p>
    </section>

    <script type="module" src="/scripts/performance-demos.js"></script>
</DocsLayout>
