---
import DocsLayout from '../../../layouts/DocsLayout.astro';
---

<DocsLayout
    title="Specificity Graph"
    description="Visual CSS specificity graph tool."
>
    <section class="site-hero">
        <p class="eyebrow">Tool</p>

        <h1>
            Specificity graph
        </h1>

        <p class="intro">
            Visualise how selector complexity affects specificity weight.
        </p>
    </section>

    <section class="content-block">
        <form class="tool-panel" data-specificity-graph>
            <label for="specificity-selector">
                Selector
            </label>

            <input
                id="specificity-selector"
                class="tool-input"
                type="text"
                value=".product-card > .title"
                data-specificity-selector
            />
        </form>
    </section>

    <section class="content-block">
        <div class="specificity-bars">
            <div>
                <p>IDs</p>
                <div class="specificity-bar">
                    <span data-bar-ids></span>
                </div>
            </div>

            <div>
                <p>Classes</p>
                <div class="specificity-bar">
                    <span data-bar-classes></span>
                </div>
            </div>

            <div>
                <p>Elements</p>
                <div class="specificity-bar">
                    <span data-bar-elements></span>
                </div>
            </div>
        </div>
    </section>

    <script type="module" src="/scripts/specificity-graph.js"></script>
</DocsLayout>
