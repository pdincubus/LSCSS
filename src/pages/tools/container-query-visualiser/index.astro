---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeExample from '../../../components/CodeExample.astro';

const containerQueryExample = `.container-demo-wrap {
    container-type: inline-size;
}

@container (min-width: 36rem) {
    .container-demo-card {
        grid-template-columns: 12rem 1fr;
    }
}`;
---

<DocsLayout
    title="Container Query Visualiser"
    description="Interactive container query visualiser for modern component architecture."
>
    <section class="site-hero">
        <p class="eyebrow">Tool</p>

        <h1>
            Container query visualiser
        </h1>

        <p class="intro">
            Resize the component container to see how component-driven
            responsiveness differs from viewport-driven responsiveness.
        </p>
    </section>

    <section class="content-block">
        <form class="tool-panel" data-container-query-tool>
            <label for="container-width">
                Container width
            </label>

            <input
                id="container-width"
                type="range"
                min="260"
                max="820"
                value="420"
                data-container-width
            />

            <output data-container-output>
                420px
            </output>
        </form>
    </section>

    <section class="content-block">
        <div class="container-demo-wrap" data-container-demo-wrap>
            <article class="container-demo-card">
                <div class="media">
                    Media
                </div>

                <div class="content">
                    <h2 class="title">
                        Component-driven layout
                    </h2>

                    <p>
                        This component changes when its own container is wide
                        enough, not when the viewport changes.
                    </p>
                </div>
            </article>
        </div>
    </section>

    <section class="content-block">
        <CodeExample code={containerQueryExample} />
    </section>

    <script type="module" src="/scripts/container-query-visualiser.js"></script>
</DocsLayout>
