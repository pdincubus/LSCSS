---
import DocsLayout from '../../../layouts/DocsLayout.astro';
---

<DocsLayout
    title="Accessibility Failure Demos"
    description="Before and after CSS accessibility failure demos."
>
    <section class="site-hero">
        <p class="eyebrow">Tool</p>

        <h1>
            Accessibility failure demos
        </h1>

        <p class="intro">
            Common CSS decisions can create real accessibility failures. These
            examples show the failure first, then the safer LSCSS-style fix.
        </p>
    </section>

    <section class="content-block">
        <h2>
            Invisible focus
        </h2>

        <div class="failure-grid">
            <article class="failure-card failure-card--bad">
                <h3>Problem</h3>

                <button class="bad-focus-button" type="button">
                    No visible focus
                </button>
            </article>

            <article class="failure-card failure-card--good">
                <h3>Fix</h3>

                <button class="good-focus-button" type="button">
                    Clear visible focus
                </button>
            </article>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Hover-only content
        </h2>

        <div class="failure-grid">
            <article class="failure-card hover-only-card">
                <h3>Problem</h3>

                <button type="button">
                    Hover only
                </button>

                <p class="hint">
                    Keyboard users may never see this.
                </p>
            </article>

            <article class="failure-card focus-aware-card">
                <h3>Fix</h3>

                <button type="button">
                    Hover or focus
                </button>

                <p class="hint">
                    This appears on hover and keyboard focus.
                </p>
            </article>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Low contrast</h2>

        <div class="failure-grid">
            <article class="failure-card low-contrast-card">
                <h3>Problem</h3>

                <p>
                    This text is difficult to read.
                </p>
            </article>

            <article class="failure-card readable-contrast-card">
                <h3>Fix</h3>

                <p>
                    This text has clearer contrast.
                </p>
            </article>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Overflow at zoom
        </h2>

        <div class="failure-grid">
            <article class="failure-card clipped-card">
                <h3>Problem</h3>

                <p>
                    This panel has a fixed width and clips content when space is
                    limited.
                </p>
            </article>

            <article class="failure-card resilient-card">
                <h3>Fix</h3>

                <p>
                    This panel uses fluid sizing and allows content to wrap.
                </p>
            </article>
        </div>
    </section>

    <section class="content-block">
        <h2>
            Motion without preference support
        </h2>

        <div class="failure-grid">
            <article class="failure-card motion-problem-card">
                <h3>Problem</h3>

                <div class="problem-spinner" aria-hidden="true"></div>
            </article>

            <article class="failure-card motion-safe-card">
                <h3>Fix</h3>

                <div class="safe-spinner" aria-hidden="true"></div>
            </article>
        </div>
    </section>
</DocsLayout>
