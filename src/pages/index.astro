---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeExample from '../components/CodeExample.astro';

const folderStructureExample = `css/
    settings/
    base/
    utilities/
    layout/
    components/
    theme/
    legacy/
    hacks/`;
---

<BaseLayout
    title="LSCSS. Layered Semantic CSS"
    description="A practical CSS methodology for layers, semantic naming, shallow selectors, modifiers, state classes, and maintainable front-end architecture."
>
    <main class="page-shell">
        <section class="site-hero">
            <p class="eyebrow">CSS methodology</p>

            <h1>
                Layered Semantic CSS
            </h1>

            <p class="intro">
                CSS architecture for teams tired of specificity wars, giant
                stylesheets, random utility chains, and one button turning
                purple for no documented reason.
            </p>

            <div class="hero-actions">
                <a href="/methodology/">Start with the methodology</a>
                <a href="/playground/">Try the playground</a>
            </div>
        </section>

        <section class="content-block">
            <h2>
                What LSCSS solves
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        Predictable overrides
                    </h3>

                    <p>
                        Use cascade layers before specificity fights begin.
                        Override order should be architecture, not luck.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        Maintainable components
                    </h3>

                    <p>
                        Use semantic component names, shallow selectors,
                        explicit modifiers, and state classes people can still
                        understand six months later.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        Safer long-term systems
                    </h3>

                    <p>
                        Keep legacy low, hacks visible, tokens consistent, and
                        file size under control so maintenance stays possible.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Quick start
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/principles/">1. Learn the principles</a>
                    </h3>

                    <p>
                        Understand layers, naming, modifiers, state classes,
                        shallow selectors, and how the architecture fits together.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/decision-trees/">2. Use the decision trees</a>
                    </h3>

                    <p>
                        Decide whether something belongs in utilities, theme,
                        modifiers, state, hacks, or a proper component.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/starter-template/">3. Start with the template</a>
                    </h3>

                    <p>
                        Use a sensible project structure before your root CSS
                        file becomes an archaeological dig site.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Common routes
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/decision-trees/">I need to make a CSS decision</a>
                    </h3>

                    <p>
                        Use decision trees for layers, modifiers, state,
                        utilities, @scope, theme, and hacks.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/migration/">I need to migrate legacy CSS</a>
                    </h3>

                    <p>
                        Improve existing projects without rewriting everything
                        for sport and upsetting everyone involved.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/comparisons/">I need to compare approaches</a>
                    </h3>

                    <p>
                        Compare LSCSS with BEM, Tailwind, CSS Modules,
                        utility-first workflows, and native @scope.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Featured tools
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3><a href="/specificity-visualiser/">Specificity visualiser</a></h3>
                    <p>See why selectors win and why layers usually matter first.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/playground/live-editor/">Live CSS editor</a></h3>
                    <p>Break components on purpose and learn how to fix them properly.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/tools/container-query-visualiser/">Container query visualiser</a></h3>
                    <p>Test component-led responsiveness without viewport guesswork.</p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Starter structure
            </h2>

            <CodeExample code={folderStructureExample} language="text" />

            <p>
                Good architecture should remove repeated decisions. Start with
                structure first, not emergency fixes later.
            </p>
        </section>
    </main>
</BaseLayout>
