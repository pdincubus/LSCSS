---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeExample from '../components/CodeExample.astro';

const folderStructureExample = `css/
    settings/
    base/
    utilities/
    layout/
    components/
    theme/
    legacy/
    hacks/`;
---

<BaseLayout
    title="LSCSS. Layered Semantic CSS"
    description="A practical CSS methodology for cascade layers, semantic naming, shallow selectors, clear modifiers, and explicit state classes."
>
    <main class="page-shell">
        <section class="site-hero">
            <p class="eyebrow">CSS methodology</p>

            <h1>
                Layered Semantic CSS
            </h1>

            <p class="intro">
                A practical CSS methodology for cascade layers, semantic naming,
                shallow selectors, clear modifiers, and explicit state classes.
            </p>

            <div class="hero-actions">
                <a href="/principles/">Start reading</a>
                <a href="/search/">Search the docs</a>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Popular paths
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/decision-trees/">I need to make a CSS decision</a>
                    </h3>

                    <p>
                        Use the decision trees when choosing between layers,
                        modifiers, state classes, @scope, utilities, or hacks.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/migration/">I need to migrate existing CSS</a>
                    </h3>

                    <p>
                        Follow a gradual adoption path for legacy CSS without a
                        full rewrite.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/examples/">I want practical examples</a>
                    </h3>

                    <p>
                        Start with real component patterns, compare good and bad
                        examples, then try them in the playground.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Featured tools
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/tools/specificity-calculator/">Specificity calculator</a>
                    </h3>

                    <p>
                        Compare selector weight and check whether a proposed
                        selector is about to create an override problem.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/tools/container-query-visualiser/">Container query visualiser</a>
                    </h3>

                    <p>
                        Resize a component container and see how component-led
                        responsiveness differs from viewport-led layout.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/tools/accessibility-demos/">Accessibility demos</a>
                    </h3>

                    <p>
                        Explore focus styles, reduced motion, logical properties,
                        and interaction states as part of CSS architecture.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/tools/performance-demos/">Performance demos</a>
                    </h3>

                    <p>
                        Review bundle size, third-party CSS isolation, animation
                        choices, and long-term performance trade-offs.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/tools/browser-support-demos/">Browser support demos</a>
                    </h3>

                    <p>
                        Explore progressive enhancement and feature-based
                        browser support decisions.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/playground/live-editor/">Live CSS editor</a>
                    </h3>

                    <p>
                        Edit CSS directly and test LSCSS component patterns in a
                        small live example.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                What CSS methodologies try to solve
            </h2>

            <ul>
                <li>naming inconsistency</li>
                <li>selector chaos</li>
                <li>specificity battles</li>
                <li>reuse problems</li>
                <li>maintenance pain at scale</li>
            </ul>
        </section>

        <section class="content-block">
            <h2>
                Core principles
            </h2>

            <ul>
                <li>organise CSS in explicit layers</li>
                <li>keep styles in partials, not root files</li>
                <li>use semantic component names</li>
                <li>use shallow scoped child selectors</li>
                <li>use explicit modifier classes</li>
                <li>use state classes for temporary or conditional states</li>
                <li>keep nesting minimal</li>
                <li>avoid hacks and isolate them when unavoidable</li>
                <li>let tooling handle browser support work</li>
            </ul>
        </section>

        <section class="content-block">
            <h2>
                Example structure
            </h2>

            <CodeExample code={folderStructureExample} language="text" />
        </section>

        <section class="content-block">
            <h2>
                Explore by topic
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3><a href="/layers/">Core methodology</a></h3>
                    <p>Understand layers, naming, architecture, utilities, theme rules, and hacks.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/modern-css/">Modern CSS</a></h3>
                    <p>Learn how :where(), :has(), nesting, @scope, and container queries fit LSCSS.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/tools/">Tools and demos</a></h3>
                    <p>Use interactive demos to explore specificity, scope, accessibility, and performance.</p>
                </article>
            </div>
        </section>
    </main>
</BaseLayout>
