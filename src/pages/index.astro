---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeExample from '../components/CodeExample.astro';

const folderStructureExample = `css/
    settings/
    base/
    utilities/
    layout/
    components/
    theme/
    legacy/
    hacks/`;
---

<BaseLayout
    title="LSCSS. Layered Semantic CSS"
    description="A practical CSS methodology for cascade layers, semantic naming, shallow selectors, clear modifiers, and explicit state classes."
>
    <main class="page-shell">
        <section class="site-hero">
            <p class="eyebrow">CSS methodology</p>

            <h1>
                Layered Semantic CSS
            </h1>

            <p class="intro">
                A practical CSS methodology for cascade layers, semantic naming,
                shallow selectors, clear modifiers, and explicit state classes.
            </p>

            <div class="hero-actions">
                <a href="/principles/">Start reading</a>
                <a href="/search/">Search the docs</a>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Quick start
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/principles/">1. Learn the principles</a>
                    </h3>

                    <p>
                        Understand layers, naming, modifiers, state classes,
                        shallow selectors, and how the architecture fits together.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/decision-trees/">2. Use the decision trees</a>
                    </h3>

                    <p>
                        Work out whether you need a utility, modifier, state
                        class, @scope rule, theme layer, or isolated hack.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/tools/">3. Try the tools</a>
                    </h3>

                    <p>
                        Use live demos and visualisers to test decisions before
                        they become expensive technical debt.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Popular paths
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/decision-trees/">I need to make a CSS decision</a>
                    </h3>

                    <p>
                        Use the decision trees when choosing between layers,
                        modifiers, state classes, @scope, utilities, or hacks.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/migration/">I need to migrate existing CSS</a>
                    </h3>

                    <p>
                        Follow a gradual adoption path for legacy CSS without a
                        full rewrite.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/examples/">I want practical examples</a>
                    </h3>

                    <p>
                        Start with real component patterns, compare good and bad
                        examples, then try them in the playground.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Featured tools
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3><a href="/tools/specificity-calculator/">Specificity calculator</a></h3>
                    <p>Compare selector weight and avoid override chaos before it starts.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/tools/container-query-visualiser/">Container query visualiser</a></h3>
                    <p>See how component-led responsiveness behaves inside real containers.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/tools/accessibility-demos/">Accessibility demos</a></h3>
                    <p>Explore focus states, reduced motion, and interaction patterns.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/tools/performance-demos/">Performance demos</a></h3>
                    <p>Review animation cost, CSS weight, and long-term performance trade-offs.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/tools/browser-support-demos/">Browser support demos</a></h3>
                    <p>Use feature support instead of outdated browser version guessing.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/playground/live-editor/">Live CSS editor</a></h3>
                    <p>Test LSCSS patterns directly in a small live component sandbox.</p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Example structure
            </h2>

            <CodeExample code={folderStructureExample} language="text" />
        </section>
    </main>
</BaseLayout>
