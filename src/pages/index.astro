---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeExample from '../components/CodeExample.astro';

const folderStructureExample = `css/
    settings/
    base/
    utilities/
    layout/
    components/
    theme/
    legacy/
    hacks/`;
---

<BaseLayout
    title="LSCSS. Layered Semantic CSS"
    description="A practical CSS methodology for layers, semantic naming, shallow selectors, modifiers, state classes, and maintainable front-end architecture."
>
    <main class="page-shell">
        <section class="site-hero">
            <p class="eyebrow">Layered Semantic CSS</p>

            <h1>
                CSS architecture that stays calm under pressure
            </h1>

            <p class="intro">
                A practical front-end methodology for teams tired of specificity
                wars, fragile overrides, utility soup, and shared stylesheets
                that are difficult to maintain.
            </p>

            <div class="hero-actions">
                <a href="/learn/what-is-lscss/">Start here</a>
                <a href="/teams/teaching-deck/">Explain it to a team</a>
            </div>
        </section>

        <section class="content-block">
            <h2>
                The shortest explanation
            </h2>

            <p>
                LSCSS means Layered Semantic CSS.
            </p>

            <p>
                The goal is not clever CSS. The goal is calm CSS.
            </p>

            <p>
                Good CSS should feel boring, predictable, and safe to change.
                If nobody is afraid to touch it, the architecture is probably working.
            </p>

            <p>
                This methodology is practitioner-led. It is based on years of
                real project delivery, not a formal benchmark dataset.
            </p>
        </section>

        <section class="content-block">
            <h2>
                Start here
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/learn/what-is-lscss/">1. What is LSCSS?</a>
                    </h3>

                    <p>
                        The front door. Understand what it is, why it exists,
                        and what problems it solves.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/learn/principles/">2. Learn the principles</a>
                    </h3>

                    <p>
                        The non-negotiables. Ownership, layers, utilities,
                        hacks, tokens, and calm CSS.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/apply/decision-trees/">3. Use the decision trees</a>
                    </h3>

                    <p>
                        Decide where CSS belongs before specificity gets involved.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Common routes
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/apply/examples/">Show me examples</a>
                    </h3>

                    <p>
                        Before and after code examples for real architectural problems.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/apply/migration/">I need to improve legacy CSS</a>
                    </h3>

                    <p>
                        Reduce risk without rewriting everything at once.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/apply/audit-checklist/">I need to audit a codebase</a>
                    </h3>

                    <p>
                        Review ownership, overrides, tokens, utilities, and delivery risk.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Team adoption
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3>
                        <a href="/teams/adoption/">Adoption</a>
                    </h3>

                    <p>
                        Introduce LSCSS without forcing a disruptive rewrite.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/teams/governance/">Governance</a>
                    </h3>

                    <p>
                        Keep standards healthy after the kickoff meeting ends.
                    </p>
                </article>

                <article class="hub-card">
                    <h3>
                        <a href="/teams/contributing/">Contribution standards</a>
                    </h3>

                    <p>
                        Keep pull requests maintainable over time.
                    </p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Featured pages
            </h2>

            <div class="hub-card-grid">
                <article class="hub-card">
                    <h3><a href="/apply/decision-trees/">Decision trees</a></h3>
                    <p>Use practical rules before CSS choices become hard to unwind.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/apply/live-examples/">Live examples</a></h3>
                    <p>Review rendered component examples that reflect LSCSS architecture decisions.</p>
                </article>

                <article class="hub-card">
                    <h3><a href="/writing/guides/performance-and-css/">Performance and CSS</a></h3>
                    <p>Improve architecture decisions that affect long-term front-end performance.</p>
                </article>
            </div>
        </section>

        <section class="content-block">
            <h2>
                Starter structure
            </h2>

            <CodeExample code={folderStructureExample} language="text" />

            <p>
                Good architecture removes repeated decisions. Start with
                structure first, not emergency fixes later.
            </p>
        </section>
    </main>
</BaseLayout>
