---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const utilityExamples = `.visually-hidden
.flow
.text-center`;
---

<DocsLayout
    title="LSCSS Utilities"
    description="Utility classes in Layered Semantic CSS."
>
    <section class="site-hero">
        <p class="eyebrow">Utilities</p>

        <h1>
            Utility classes
        </h1>

        <p class="intro">
            Utilities should remain small, explicit, and low complexity.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={utilityExamples} />
    </section>

    <section class="content-block">
        <p>
            Utilities should not replace semantic component structure.
        </p>
    </section>
</DocsLayout>
