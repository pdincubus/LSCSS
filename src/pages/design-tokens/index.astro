---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const tokenExample = `:root {
    --colour-background: white;
    --colour-text: black;

    --space-s: 0.5rem;
    --space-m: 1rem;
    --space-l: 2rem;
}`;
---

<DocsLayout
    title="Design Tokens"
    description="Design token strategy in Layered Semantic CSS."
>
    <section class="site-hero">
        <p class="eyebrow">Design tokens</p>

        <h1>
            Design token strategy
        </h1>

        <p class="intro">
            Design tokens should remain semantic, predictable, and scalable.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={tokenExample} />
    </section>

    <section class="content-block">
        <ul>
            <li>prefer semantic naming</li>
            <li>avoid arbitrary values</li>
            <li>keep spacing predictable</li>
            <li>support theming cleanly</li>
            <li>avoid token duplication</li>
        </ul>
    </section>
</DocsLayout>
