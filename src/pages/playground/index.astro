---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const playgroundExample = `.feature-panel {
    display: grid;
    gap: var(--space-m);
}

.feature-panel > .title {
    margin: 0;
}

.feature-panel--highlighted {
    border-color: var(--colour-accent);
}`;
---

<DocsLayout
    title="LSCSS Playground"
    description="Experimenting with Layered Semantic CSS patterns."
>
    <section class="site-hero">
        <p class="eyebrow">Playground</p>

        <h1>
            Playground
        </h1>

        <p class="intro">
            A space for testing component structure, naming, and layering.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={playgroundExample} />
    </section>
</DocsLayout>
