---
import DocsLayout from '../../../layouts/DocsLayout.astro';

const defaultCss = `@layer components {
    .playground-card {
        padding: var(--space-m, 1rem);
        border: 1px solid currentColor;
        display: grid;
        gap: 1rem;
    }

    .playground-card > .title {
        margin: 0;
    }

    .playground-card--featured {
        border-color: var(--colour-accent, rebeccapurple);
    }
}`;
---

<DocsLayout
    title="Live CSS Playground"
    description="Interactive live CSS playground for Layered Semantic CSS experiments."
>
    <section class="site-hero">
        <p class="eyebrow">Playground</p>

        <h1>
            Live CSS playground
        </h1>

        <p class="intro">
            Edit CSS and immediately see architectural decisions, not only visual changes.
        </p>
    </section>

    <nav class="section-nav" aria-label="Live playground sections">
        <a href="#editor">Editor</a>
        <a href="#experiments">Experiments</a>
        <a href="#preview">Preview</a>
    </nav>

    <section id="editor" class="content-block">
        <h2>
            CSS editor
        </h2>

        <p>
            Start with a semantic component, a short child selector, and one modifier.
            Then try breaking it on purpose.
        </p>

        <div class="tool-panel">
            <label for="live-css">
                CSS
            </label>

            <textarea id="live-css" class="tool-input" rows="18" data-live-css>{defaultCss}</textarea>
        </div>
    </section>

    <section id="experiments" class="content-block">
        <h2>
            Guided experiments
        </h2>

        <ol>
            <li>Add one extra level of selector nesting and see how readability changes.</li>
            <li>Replace the modifier with an <code>.is_active</code> state class and compare intent.</li>
            <li>Replace the token value with a random hard-coded colour.</li>
            <li>Move the rule outside <code>@layer components</code> and test override behaviour.</li>
            <li>Add a utility class and decide whether it should really be a component.</li>
        </ol>
    </section>

    <section id="preview" class="content-block">
        <h2>
            Live preview
        </h2>

        <style data-playground-style></style>

        <article class="playground-card playground-card--featured">
            <h2 class="title">
                Playground component
            </h2>

            <p>
                Test modifiers, state, layers, and selector decisions here.
            </p>
        </article>
    </section>

    <script type="module" src="/scripts/live-playground.js"></script>
</DocsLayout>
