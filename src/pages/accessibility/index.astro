---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const reducedMotionExample = `@media (prefers-reduced-motion: reduce) {
    * {
        animation-duration: 0s;
    }
}`;
---

<DocsLayout
    title="Accessibility and CSS"
    description="Accessibility-first CSS architecture guidance."
>
    <section class="site-hero">
        <p class="eyebrow">Accessibility</p>

        <h1>
            Accessibility-first CSS
        </h1>

        <p class="intro">
            CSS architecture should support accessibility rather than fight it.
        </p>
    </section>

    <section class="content-block">
        <ul>
            <li>visible focus states</li>
            <li>reduced motion support</li>
            <li>forced colours support</li>
            <li>logical properties</li>
            <li>reflow and zoom resilience</li>
            <li>readable spacing</li>
            <li>accessible target sizing</li>
            <li>contrast strategy</li>
        </ul>
    </section>

    <section class="content-block">
        <CodeExample code={reducedMotionExample} language="css" />
    </section>
</DocsLayout>
