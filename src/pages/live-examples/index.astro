---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const exampleCardCss = `.example-card {
    display: grid;
    gap: var(--space-m);
}

.example-card > .title {
    margin: 0;
}`;
---

<DocsLayout
    title="Live Component Examples"
    description="Rendered component examples using Layered Semantic CSS principles."
>
    <section class="site-hero">
        <p class="eyebrow">Live examples</p>

        <h1>
            Live component examples
        </h1>

        <p class="intro">
            Practical examples combining semantic structure, layers,
            accessibility, and modern CSS features.
        </p>
    </section>

    <section class="content-block">
        <article class="example-card">
            <h2 class="title">
                Product card
            </h2>

            <p>
                Example semantic component structure using shallow selectors.
            </p>

            <a class="button" href="#">
                View product
            </a>
        </article>
    </section>

    <section class="content-block">
        <CodeExample code={exampleCardCss} />
    </section>
</DocsLayout>
