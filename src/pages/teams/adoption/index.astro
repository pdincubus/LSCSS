---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import HubCard from '../../../components/HubCard.astro';
import MigrationEffort from '../../../components/MigrationEffort.astro';
import MigrationMilestones from '../../../components/MigrationMilestones.astro';
import MigrationSteps from '../../../components/MigrationSteps.astro';

const adoptionPrinciples = [
    'Do not begin with a rewrite pitch.',
    'Fix active work first, not low-impact historical code.',
    'Make good defaults easier than bad habits.',
    'Use reviews to teach patterns, not punish people.',
    'Protect the system with tooling where possible.'
];

const fitSignals = [
    {
        phase: 'Fit signal',
        title: 'Strong fit',
        description: 'Shared codebase, recurring overrides, and unclear ownership.'
    },
    {
        phase: 'Fit signal',
        title: 'Good fit',
        description: 'Scaling team, inconsistent review outcomes, and a growing legacy layer.'
    },
    {
        phase: 'Fit signal',
        title: 'Lower urgency',
        description: 'Small single-owner project with stable scope and low CSS churn.'
    }
];

const rolloutSteps = [
    'Week 1. Define layers and starter rules.',
    'Week 2. Stop new CSS from creating old problems.',
    'Week 3. Improve active components only.',
    'Week 4 onwards. Reduce legacy safely over time.'
];

const expectedEffort = [
    {
        size: 'Small project (1-3 contributors)',
        duration: '1-2 weeks',
        note: 'Enough to establish baseline rules and stop new entropy.'
    },
    {
        size: 'Mid-size project (4-10 contributors)',
        duration: '2-6 weeks',
        note: 'Typical range to stabilize layers, review habits, and team expectations.'
    },
    {
        size: 'Large project (multiple teams)',
        duration: '1-2 quarters',
        note: 'Common range for full rollout with governance and cross-team alignment.'
    }
];
---

<DocsLayout
    title="Adopting LSCSS"
    description="How to introduce Layered Semantic CSS to an existing team with minimal disruption."
    schemaType="TechArticle"
>
    <section class="site-hero">
        <p class="eyebrow">Teams</p>
        <h1>How to introduce LSCSS to a team</h1>
        <p class="intro">
            Good CSS architecture fails when teams treat it like a naming debate
            instead of a delivery problem. Adoption works when people see less
            pain, fewer regressions, and clearer ownership.
        </p>
        <p>
            The recommendations on this page come from hands-on project work and
            repeatable team practices, not a formal metrics program.
        </p>
    </section>

    <nav class="section-nav" aria-label="Adoption sections">
        <a href="#first">Start first</a>
        <a href="#principles">Principles</a>
        <a href="#rollout">Rollout</a>
        <a href="#reviews">Code reviews</a>
        <a href="#mistakes">Common mistakes</a>
    </nav>

    <section class="content-block">
        <h2 id="first">Ask this first</h2>
        <p>
            <strong>Ask first:</strong> Are you changing the system,
            or trying to win an argument?
        </p>
        <p>
            If people do not understand the problem,
            they will not protect the solution.
        </p>
        <p>
            Most resistance is not about CSS. It is about trust, delivery risk,
            and people assuming change means rewriting everything on a Friday.
        </p>
    </section>

    <section class="content-block">
        <h2 id="principles">Adoption principles</h2>
        <MigrationSteps steps={adoptionPrinciples} />
        <p>
            The goal is not perfect CSS. The goal is fewer expensive mistakes.
        </p>
    </section>

    <section class="content-block">
        <h2>Is LSCSS a fit right now?</h2>
        <MigrationMilestones milestones={fitSignals} />
        <p>
            Even on lower-urgency projects, introducing layers and naming discipline early
            can prevent expensive cleanup later.
        </p>
    </section>

    <section class="content-block">
        <h2 id="rollout">Recommended rollout</h2>
        <p>A sensible default sequence looks like this:</p>
        <MigrationSteps steps={rolloutSteps} />
        <p>
            Introduce layers first. This creates immediate override control and
            stops specificity wars breeding while the rest of the system catches up.
        </p>
        <h3>Expected effort by project size</h3>
        <MigrationEffort tiers={expectedEffort} />
    </section>

    <section class="content-block">
        <h2 id="reviews">Use code reviews as architecture training</h2>
        <ul>
            <li>Does this belong in base, theme, or component?</li>
            <li>Is this state or a modifier?</li>
            <li>Why does this need a utility instead of a component?</li>
            <li>Why is specificity increasing here?</li>
            <li>Is this a hack or a real fix?</li>
        </ul>
        <p>
            Repeated review questions become team rules. That is how adoption sticks.
        </p>
    </section>

    <section class="content-block">
        <h2 id="mistakes">Common adoption mistakes</h2>
        <ul>
            <li>Trying to rename everything before fixing architecture.</li>
            <li>Letting legacy CSS quietly move into component files.</li>
            <li>Creating utilities for every inconvenience.</li>
            <li>Treating hacks as permanent roommates.</li>
            <li>Explaining rules without showing practical examples.</li>
        </ul>
        <p>
            If adoption feels like policy instead of relief, people will route around it.
        </p>
    </section>

    <section class="content-block">
        <h2>Next useful pages</h2>
        <div class="hub-grid">
            <HubCard href="/apply/starter-template/" title="Starter template">
                <p>Give teams a real structure instead of abstract rules.</p>
            </HubCard>
            <HubCard href="/apply/decision-trees/" title="Decision trees">
                <p>Turn architecture principles into repeatable daily choices.</p>
            </HubCard>
            <HubCard href="/apply/migration/" title="Migration">
                <p>Improve legacy systems safely without large, high-risk rewrites.</p>
            </HubCard>
        </div>
    </section>
</DocsLayout>
