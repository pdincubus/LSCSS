---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeExample from '../../../components/CodeExample.astro';

const utilityOrComponent = `Does this solve a universal accessibility problem?

Yes → Utility

No ↓

Does this same pattern repeat together often?

Yes → Component

No ↓

Is it only a small one-off visual adjustment?

Yes → Theme

No ↓

If you need to explain it twice,
it probably needs a component`;

const modifierOrState = `Is this a permanent reusable variation?

Yes → Modifier

No ↓

Is this temporary, conditional, or JS-driven?

Yes → State class

No ↓

If it disappears when the user leaves,
it is probably state`;

const baseThemeComponent = `Should this apply globally across the whole site?

Yes → Base

No ↓

Is this only visual presentation?

Yes → Theme

No ↓

Is this specific to one UI pattern?

Yes → Component

No ↓

You are probably writing a hack`;

const hackOrFix = `Is this urgent and temporary?

Yes → Hacks layer

No ↓

Will this still exist in 6 months?

Yes → Real fix

No ↓

If it feels permanent,
stop calling it temporary`;

const layoutOrComponent = `Is the issue about page structure and positioning?

Yes → Layout

No ↓

Is it specific to one reusable UI pattern?

Yes → Component

No ↓

If three components share it,
it is probably layout`;

const scopeBemNeither = `Do you need native selector boundaries?

Yes → @scope

No ↓

Do you need explicit naming for legacy teams?

Yes → BEM may help

No ↓

Use semantic ownership and shallow selectors`;

const firstQuestionExample = `Stop adding specificity first.

Ask:
Am I changing behaviour, presentation,
structure, or temporary state?

That answer decides the destination before writing CSS.`;
---

<DocsLayout
    title="CSS Architecture Decision Trees"
    description="Decision trees for choosing utilities, components, modifiers, state, layers, hacks, theme rules, and modern CSS architecture patterns."
    schemaType="TechArticle"
>
    <section class="site-hero">
        <p class="eyebrow">Decision trees</p>
        <h1>CSS architecture decision trees</h1>
        <p class="intro">
            Use these when CSS arguments start, code reviews lose clarity, or
            someone reaches for !important before asking where the code belongs.
        </p>
    </section>

    <nav class="section-nav" aria-label="Decision tree sections">
        <a href="#first">Start first</a>
        <a href="#utility">Utility or component</a>
        <a href="#state">Modifier or state</a>
        <a href="#ownership">Base, theme, or component</a>
        <a href="#hacks">Hack or real fix</a>
        <a href="#layout">Layout or component</a>
        <a href="#scope">Scope, BEM, or neither</a>
    </nav>

    <section id="first" class="content-block">
        <h2>Ask this first</h2>
        <CodeExample code={firstQuestionExample} language="text" />
        <p>
            Most bad CSS starts with the wrong destination, not the wrong selector.
            Decide ownership first.
        </p>
    </section>

    <section id="utility" class="content-block">
        <h2>Utility or component?</h2>
        <CodeExample code={utilityOrComponent} language="text" />
    </section>

    <section id="state" class="content-block">
        <h2>Modifier or state?</h2>
        <CodeExample code={modifierOrState} language="text" />
    </section>

    <section id="ownership" class="content-block">
        <h2>Base vs theme vs component</h2>
        <CodeExample code={baseThemeComponent} language="text" />
    </section>

    <section id="hacks" class="content-block">
        <h2>Hack or real fix?</h2>
        <CodeExample code={hackOrFix} language="text" />
    </section>

    <section id="layout" class="content-block">
        <h2>Layout problem or component problem?</h2>
        <CodeExample code={layoutOrComponent} language="text" />
    </section>

    <section id="scope" class="content-block">
        <h2>@scope, BEM, or neither?</h2>
        <CodeExample code={scopeBemNeither} language="text" />
    </section>

    <section class="content-block">
        <h2>Next useful pages</h2>
        <div class="hub-card-grid">
            <article class="hub-card">
                <h3><a href="/apply/layers/">Layers</a></h3>
                <p>Control precedence before increasing specificity.</p>
            </article>
            <article class="hub-card">
                <h3><a href="/apply/starter-template/">Starter template</a></h3>
                <p>See where these decisions live inside a real project structure.</p>
            </article>
            <article class="hub-card">
                <h3><a href="/learn/anti-pattern-gallery/">Anti-pattern gallery</a></h3>
                <p>Recognise the mistakes these decision trees are trying to prevent.</p>
            </article>
        </div>
    </section>
</DocsLayout>
