---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import DecisionTree from '../../../components/DecisionTree.astro';
import HubCard from '../../../components/HubCard.astro';
import {
    baseThemeComponent,
    hackOrFix,
    layoutOrComponent,
    modifierOrState,
    scopeBemNeither,
    utilityOrComponent
} from '../../../data/decisionTrees';
---

<DocsLayout
    title="CSS Architecture Decision Trees"
    description="Decision trees for choosing utilities, components, modifiers, state, layers, hacks, theme rules, and modern CSS architecture patterns."
    schemaType="TechArticle"
>
    <section class="site-hero">
        <p class="eyebrow">Apply</p>
        <h1>CSS architecture decision trees</h1>
        <p class="intro">
            Use these when CSS arguments start, code reviews lose clarity, or
            someone reaches for <code>!important</code> before asking where the code belongs.
        </p>
    </section>

    <nav class="section-nav" aria-label="Decision tree sections">
        <a href="#first">Start first</a>
        <a href="#utility">Utility or component</a>
        <a href="#state">Modifier or state</a>
        <a href="#ownership">Base, theme, or component</a>
        <a href="#hacks">Hack or real fix</a>
        <a href="#layout">Layout or component</a>
        <a href="#scope">Scope, BEM, or neither</a>
    </nav>

    <section class="content-block">
        <h2 id="first">Ask this first</h2>
        <p>
            Stop adding specificity first.
        </p>
        <p>
            <strong>Ask:</strong> Am I changing behaviour, presentation, structure, or temporary state?
            That answer decides the destination before writing CSS.
        </p>
        <p>
            Most bad CSS starts with the wrong destination, not the wrong selector.
            Decide ownership first.
        </p>
    </section>

    <section class="content-block">
        <h2 id="utility">Utility or component?</h2>
        <DecisionTree tree={utilityOrComponent} />
    </section>

    <section class="content-block">
        <h2 id="state">Modifier or state?</h2>
        <DecisionTree tree={modifierOrState} />
    </section>

    <section class="content-block">
        <h2 id="ownership">Base vs theme vs component</h2>
        <DecisionTree tree={baseThemeComponent} />
    </section>

    <section class="content-block">
        <h2 id="hacks">Hack or real fix?</h2>
        <DecisionTree tree={hackOrFix} />
    </section>

    <section class="content-block">
        <h2 id="layout">Layout problem or component problem?</h2>
        <DecisionTree tree={layoutOrComponent} />
    </section>

    <section class="content-block">
        <h2 id="scope">@scope, BEM, or neither?</h2>
        <DecisionTree tree={scopeBemNeither} />
    </section>

    <section class="content-block">
        <h2>Next useful pages</h2>
        <div class="hub-grid">
            <HubCard href="/apply/layers/" title="Layers">
                <p>Control precedence before increasing specificity.</p>
            </HubCard>
            <HubCard href="/apply/starter-template/" title="Starter template">
                <p>See where these decisions live inside a real project structure.</p>
            </HubCard>
            <HubCard href="/learn/anti-patterns/" title="Anti-patterns">
                <p>Recognise the mistakes these decision trees are trying to prevent.</p>
            </HubCard>
        </div>
    </section>
</DocsLayout>
