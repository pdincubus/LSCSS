---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeExample from '../../../components/CodeExample.astro';
import HubCard from '../../../components/HubCard.astro';

const exampleCardCss = `.example-card {
    display: grid;
    gap: var(--space-m);
}

.example-card > .title {
    margin: 0;
}

.example-card--featured {
    border-color: var(--colour-accent);
}`;

const stateExample = `.example-card.is_loading {
    opacity: 0.7;
    pointer-events: none;
}`;

const badExample = `.page .wrapper .card .title {
    color: red !important;
}`;

const betterExample = `@layer components, theme;

@layer theme {
    .example-card > .title {
        color: var(--colour-accent);
    }
}`;
---

<DocsLayout
    title="Live Component Examples"
    description="Rendered component examples using Layered Semantic CSS principles."
>
    <section class="site-hero">
        <p class="eyebrow">Live examples</p>

        <h1>
            Live component examples
        </h1>

        <p class="intro">
            This is where theory has to behave in public. Real rendered examples
            showing semantic structure, layers, accessibility, and modern CSS
            decisions without hiding behind diagrams.
        </p>
    </section>

    <nav class="section-nav" aria-label="Live examples sections">
        <a href="#product-card">Product card</a>
        <a href="#state">State example</a>
        <a href="#compare">Bad vs better</a>
        <a href="#next">Next examples</a>
    </nav>

    <section class="content-block">
        <h2 id="product-card">
            Product card example
        </h2>

        <article class="example-card example-card--featured">
            <h3 class="title">
                Example product
            </h3>

            <p>
                Semantic component structure using shallow selectors, deliberate
                modifiers, and predictable ownership.
            </p>

            <a class="button" href="#">
                View product
            </a>
        </article>

        <p>
            One clear parent. Short child classes. One real modifier. No utility
            soup. No deep selector chains.
        </p>
    </section>

    <section class="content-block">
        <h2>
            Product card CSS
        </h2>

        <CodeExample code={exampleCardCss} />
    </section>

    <section class="content-block">
        <h2 id="state">
            State example
        </h2>

        <p>
            Temporary behaviour should be visible and explicit. Loading is not
            a modifier pretending to be permanent architecture.
        </p>

        <CodeExample code={stateExample} />
    </section>

    <section class="content-block">
        <h2 id="compare">
            Bad versus better
        </h2>

        <p>
            Seeing the broken version first makes the architectural decision
            easier to recognise.
        </p>

        <p>
            Bad version:
        </p>

        <CodeExample code={badExample} />

        <p>
            Better version:
        </p>

        <CodeExample code={betterExample} />

        <p>
            Check layer order before increasing specificity. Most CSS fights are
            ownership problems expressed through selectors.
        </p>
    </section>

    <section class="content-block">
        <h2 id="next">
            Useful next examples
        </h2>

        <div class="hub-card-grid">
            <HubCard href="/apply/examples/" title="Practical examples">
                <p>Compare code structure and learn what good patterns look like.</p>
            </HubCard>

            <HubCard href="/apply/decision-trees/" title="Decision trees">
                <p>Use practical rules to diagnose architecture issues before implementing fixes.</p>
            </HubCard>

            <HubCard href="/learn/anti-pattern-gallery/" title="Anti-pattern gallery">
                <p>Recognize common CSS anti-patterns before they become team habits.</p>
            </HubCard>
        </div>
    </section>
</DocsLayout>
