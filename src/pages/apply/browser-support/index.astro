---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CliCommand from '../../../components/CliCommand.astro';
import CodeExample from '../../../components/CodeExample.astro';
import HubCard from '../../../components/HubCard.astro';

const browserslistRc = `# https://github.com/browserslist/browserslist
# One shared query list for Autoprefixer, Lightning CSS, @babel/preset-env, etc.

last 2 versions
> 0.5%
not dead`;

const supportsExample = `@supports (display: grid) {
    .product-grid {
        display: grid;
        gap: var(--space-m);
    }
}

@supports not (display: grid) {
    .product-grid {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-m);
    }
}`;

const popoverTransitionExample = `/* Fallback styles for old browsers first. */
.menu-popover {
    opacity: 0;
    transform: translateY(var(--space-2xs));
}

/* Progressive enhancement for browsers with popover transition support. */
@supports (transition-behavior: allow-discrete) {
    .menu-popover {
        transition:
            opacity var(--transition-s),
            transform var(--transition-s),
            overlay var(--transition-s) allow-discrete,
            display var(--transition-s) allow-discrete;
    }

    /* Open styles first, then exit/initial styles,
     * then @starting-style last because of specificity.
     * Do not change the order of these rules. */
    .menu-popover:popover-open {
        opacity: 1;
        transform: translateY(0);
    }

    .menu-popover {
        opacity: 0;
        transform: translateY(var(--space-2xs));
    }

    @starting-style {
        .menu-popover:popover-open {
            opacity: 0;
            transform: translateY(var(--space-2xs));
        }
    }
}`;

const customSelectExample = `/* Fallback styles for old browsers first. */
.form-select > select {
    inline-size: 100%;
    min-block-size: 2.75rem;
    padding: var(--space-xs) var(--space-s);
}

/* Progressive enhancement for browsers with full customisable select support. */
@supports (appearance: base-select) and selector(::picker(select)) {
    .form-select > select,
    .form-select > select::picker(select) {
        appearance: base-select;
    }

    .form-select > select {
        padding-inline-end: var(--space-xl);
    }

    .form-select > select::picker(select) {
        border: var(--border-s) solid var(--c-border);
        border-radius: var(--br-m);
        background: var(--c-surface);
    }
}`;

const disclosureTransitionExample = `/* Fallback styles for old browsers first.
 * The disclosure opens and closes with native details behaviour. */
.disclosure > details {
    border: var(--border-s) solid var(--c-border);
}

@supports selector(::details-content) {
    /* Do not change the order of these rules. */
    :root {
        interpolate-size: allow-keywords;
    }

    details[open]::details-content {
        block-size: auto;
        block-size: calc-size(auto, size);
        opacity: 1;
        content-visibility: visible;
    }

    details::details-content {
        transition:
            var(--transition-m) block-size,
            var(--transition-m) opacity,
            var(--transition-m) content-visibility allow-discrete;
        opacity: 0;
        overflow: hidden;
        block-size: 0;
        content-visibility: hidden;
    }

    @starting-style {
        details::details-content {
            block-size: 0;
            opacity: 0;
            content-visibility: visible;
        }
    }
}`;

const customMediaExample = `/* settings layer — define once */
@custom-media --desktop (width >= 1280px);
@custom-media --reduced-motion (prefers-reduced-motion: reduce);

/* component CSS — readable at authoring time */
.product-card {
    @media (--desktop) {
        grid-template-columns: repeat(3, 1fr);
    }

    @media (--reduced-motion) {
        transition: none;
    }
}

/* build output — what the browser actually parses */
/* @media (width >= 1280px) { … } */
/* @media (prefers-reduced-motion: reduce) { … } */`;

const supportMatrixTemplate = `# Browser support matrix

<!-- Copy into your repo (e.g. docs/browser-support.md). Update when policy or browserslist changes. -->

## Policy

| Field | Value |
| --- | --- |
| Last updated | YYYY-MM-DD |
| Owners | |
| Primary baseline | Feature / Version / Both |
| Browserslist | See .browserslistrc (queries and/or feature queries) |
| Next review | |

## Support tiers

- Fully supported — critical journeys meet the baseline; defects are release blockers.
- Best effort — core tasks work; minor visual differences acceptable.
- Not supported — no test commitment.

## Two ways to document the baseline

Use a feature baseline when capability matters more than a version number (CSS, JS, and platform APIs).
Use a version list when contracts, QA devices, or analytics name specific engines.
Many teams treat the feature tables as source of truth and keep versions as an optional appendix.

## Feature baseline (primary)

Policy: Required = must work everywhere you claim fully supported.
Progressive = enhanced path + documented fallback. Not used = off the table.

| Capability | Policy | Delivery | Fallback when missing | Notes |
| --- | --- | --- | --- | --- |
| Cascade layers (@layer) | | Native / Build / Not used | | |
| Design tokens (custom properties) | | Native | | |
| Custom media (@custom-media) | | Build | Plain @media or simpler layout | Every pipeline must expand |
| Container queries | | Native / Not used | | |
| Nesting | | Native / Build | Flat selectors | |
| :is(), :where(), :not() | | Native | Longer selectors | |
| :has() | | Native / @supports | Simpler DOM or JS hook | |
| @scope | | Native / Not used | Layers + naming discipline | |
| @starting-style | | Native / @supports / Not used | No entry transition | Keep standalone blocks after the original rule |
| transition-behavior | | Native / Not used | Discrete values change immediately | Needed for display, overlay, and content-visibility transitions |
| ::details-content | | Native / @supports / Not used | Native details open/close | Progressive disclosure animation only |
| interpolate-size / calc-size() | | Native / @supports / Not used | Instant intrinsic size change | Verify syntax and support before production use |
| Customisable select | | Native / @supports / Not used | Classic select | Gate with appearance + ::picker(select) |
| Logical properties | | Native | Physical properties | |

## JavaScript and platform APIs (optional, same pattern)

| Capability | Policy | Delivery | Fallback when missing | Notes |
| --- | --- | --- | --- | --- |
| ES modules | | Native / Transpile | | |
| fetch | | Native / Polyfill | | |
| dynamic import() | | Native / Transpile / Not used | | |
| IntersectionObserver | | Native / Polyfill | | |
| (add rows your app needs) | | | | |

## Browser versions (optional appendix)

| Browser / environment | Minimum version | Tier | Notes |
| --- | --- | --- | --- |
| Chrome (desktop) | | | |
| Firefox | | | |
| Safari (macOS) | | | |
| Microsoft Edge | | | |
| Safari (iOS) | | | |
| Chrome (Android) | | | |
| Samsung Internet | | | |
| Embedded webview (name product) | | | |`;
