---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const specificityExamples = `.product-card .title
:where(.product-card) .title
#app .product-card .title
@scope (.product-card) {
    .title {}
}`;

const badExample = `#app .page .wrapper .product-card .title {
    color: red !important;
}`;

const betterExample = `@layer components, theme;

@layer theme {
    .product-card > .title {
        color: var(--colour-accent);
    }
}`;
---

<DocsLayout
    title="Specificity Visualiser"
    description="A practical guide to selector specificity, cascade layers, and scoped CSS."
>
    <section class="site-hero">
        <p class="eyebrow">Tool</p>

        <h1>
            Specificity visualiser
        </h1>

        <p class="intro">
            See why selectors win, why overrides fail, and why most specificity
            problems should be solved before someone reaches for <code>!important</code>.
        </p>
    </section>

    <nav class="section-nav" aria-label="Specificity sections">
        <a href="#explains">What it explains</a>
        <a href="#compare">Compare selectors</a>
        <a href="#debug">Debug flow</a>
        <a href="#position">LSCSS position</a>
    </nav>

    <section id="explains" class="content-block">
        <h2>
            What it should explain
        </h2>

        <ul>
            <li>selector length is not the same as specificity</li>
            <li>IDs create override problems quickly</li>
            <li><code>:where()</code> removes selector weight</li>
            <li>cascade layers often solve problems before specificity matters</li>
            <li><code>@scope</code> improves ownership without increasing selector weight</li>
        </ul>
    </section>

    <section id="compare" class="content-block">
        <h2>
            Example comparisons
        </h2>

        <p>
            Compare these selectors and decide which one should win before checking.
            The goal is to understand the cascade, not memorise trivia like a CSS pub quiz.
        </p>

        <CodeExample code={specificityExamples} />
    </section>

    <section id="debug" class="content-block">
        <h2>
            Specificity debugging flow
        </h2>

        <p>
            Bad version:
        </p>

        <CodeExample code={badExample} />

        <p>
            Better version:
        </p>

        <CodeExample code={betterExample} />

        <ol>
            <li>Check layer order first.</li>
            <li>Check whether the selector is deeper than it needs to be.</li>
            <li>Check whether an ID exists for no good reason.</li>
            <li>Check whether <code>:where()</code> would remove unnecessary weight.</li>
            <li>Check whether the component should use <code>@scope</code> or a shallower selector.</li>
            <li>Only then consider changing specificity.</li>
        </ol>
    </section>

    <section id="position" class="content-block">
        <h2>
            LSCSS position
        </h2>

        <p>
            LSCSS aims to reduce specificity pressure before it needs solving.
            Layers, scope, shallow selectors, and clear component ownership
            should prevent most escalation.
        </p>

        <p>
            If the first instinct is adding another class, another wrapper, or
            another <code>!important</code>, the problem is usually architecture,
            not missing specificity.
        </p>
    </section>
</DocsLayout>
