---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeExample from '../../../components/CodeExample.astro';

const whereExample = `:where(.flow > *) + * {
    margin-block-start: var(--space-m);
}`;
---

<DocsLayout
    title=":where()"
    description="Using :where() in modern CSS architecture."
>
    <section class="site-hero">
        <p class="eyebrow">Modern CSS</p>

        <h1>
            :where()
        </h1>

        <p class="intro">
            :where() allows expressive selectors without adding specificity
            weight.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={whereExample} />
    </section>

    <section class="content-block">
        <h2>
            Architecture impact
        </h2>

        <ul>
            <li>reduces specificity debt</li>
            <li>improves utility safety</li>
            <li>makes overrides easier</li>
            <li>supports composition</li>
        </ul>
    </section>
</DocsLayout>
