            <li><a href="/modern-css/has/">:has()</a></li>
            <li><a href="/modern-css/not/">:not()</a></li>
            <li><a href="/modern-css/nesting/">CSS nesting</a></li>
            <li><a href="/modern-css/container-queries/">container queries</a></li>
            <li><a href="/modern-css/logical-properties/">logical properties</a></li>
            <li><a href="/modern-css/view-transitions/">view transitions</a></li>
        </ul>
    </section>

    <section class="content-block">
        <h2>
            LSCSS position
        </h2>

