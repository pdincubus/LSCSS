---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeExample from '../../../components/CodeExample.astro';

const isExample = `:is(h1, h2, h3) {
    line-height: 1.1;
}`;
---

<DocsLayout
    title=":is()"
    description="Using :is() in modern CSS architecture."
>
    <section class="site-hero">
        <p class="eyebrow">Modern CSS</p>

        <h1>
            :is()
        </h1>

        <p class="intro">
            :is() reduces selector duplication and improves maintainability.
        </p>
    </section>

    <section class="content-block">
        <CodeExample code={isExample} />
    </section>

    <section class="content-block">
        <h2>
            Architecture impact
        </h2>

        <ul>
            <li>reduces repeated selectors</li>
            <li>simplifies grouped patterns</li>
            <li>improves readability</li>
            <li>reduces maintenance overhead</li>
        </ul>
    </section>
</DocsLayout>
