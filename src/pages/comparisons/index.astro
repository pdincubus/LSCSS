---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
    title="LSCSS Comparisons"
    description="Comparing Layered Semantic CSS with other CSS methodologies."
>
    <main class="page-shell">
        <section class="site-hero">
            <p class="eyebrow">Comparisons</p>

            <h1>
                Methodology comparisons
            </h1>

            <p class="intro">
                Most CSS methodologies attempt to solve similar problems, but
                they approach them from different angles.
            </p>
        </section>

        <section class="content-block">
            <table class="comparison-table">
                <thead>
                    <tr>
                        <th>Methodology</th>
                        <th>Main focus</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>OOCSS</td>
                        <td>reuse</td>
                    </tr>

                    <tr>
                        <td>SMACSS</td>
                        <td>categorisation</td>
                    </tr>

                    <tr>
                        <td>BEM</td>
                        <td>naming clarity</td>
                    </tr>

                    <tr>
                        <td>ITCSS</td>
                        <td>specificity and layering</td>
                    </tr>

                    <tr>
                        <td>CUBE</td>
                        <td>modern practical architecture</td>
                    </tr>

                    <tr>
                        <td>LSCSS</td>
                        <td>layers, semantics, readability, maintainability</td>
                    </tr>
                </tbody>
            </table>
        </section>
    </main>
</BaseLayout>
