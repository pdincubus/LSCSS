---
import DocsLayout from '../../layouts/DocsLayout.astro';

const comparisons = [
    {
        title: 'BEM vs LSCSS',
        href: '/comparisons/bem-vs-lscss/',
        description: 'Naming conventions, modifiers, state classes, and modern CSS architecture.'
    },
    {
        title: 'Tailwind vs LSCSS',
        href: '/comparisons/tailwind-vs-lscss/',
        description: 'Utility-first speed versus semantic structure and long-term maintainability.'
    },
    {
        title: 'CSS Modules vs LSCSS',
        href: '/comparisons/css-modules-vs-lscss/',
        description: 'Component scoping, framework workflows, and system-wide architecture.'
    },
    {
        title: 'Utility-first vs LSCSS',
        href: '/comparisons/utility-first-vs-lscss/',
        description: 'Markup-led styling versus layered semantic CSS systems.'
    },
    {
        title: '@scope vs BEM',
        href: '/comparisons/scope-vs-bem/',
        description: 'Native browser scoping versus defensive naming conventions.'
    }
];
---

<DocsLayout
    title="CSS Architecture Comparisons"
    description="Compare BEM, Tailwind, CSS Modules, utility-first CSS, and modern CSS approaches against Layered Semantic CSS."
>
    <section class="site-hero">
        <p class="eyebrow">Comparisons</p>

        <h1>
            CSS architecture comparisons
        </h1>

        <p class="intro">
            Most front-end teams are not choosing CSS from a blank sheet. They
            are choosing between existing habits, existing pain, and existing
            opinions held with suspicious confidence.
        </p>
    </section>

    <nav class="section-nav" aria-label="Comparison sections">
        <a href="#comparison-guides">Guides</a>
        <a href="#quick-reference">Quick reference</a>
        <a href="#how-to-use">How to use this</a>
        <a href="/methodology/">Core methodology</a>
    </nav>

    <section id="comparison-guides" class="content-block">
        <h2>
            Comparison guides
        </h2>

        <div class="hub-card-grid">
            {
                comparisons.map((item) => (
                    <article class="hub-card">
                        <h3>
                            <a href={item.href}>{item.title}</a>
                        </h3>

                        <p>
                            {item.description}
                        </p>
                    </article>
                ))
            }
        </div>
    </section>

    <section id="quick-reference" class="content-block">
        <h2>
            Quick reference
        </h2>

        <table class="comparison-table">
            <thead>
                <tr>
                    <th>Approach</th>
                    <th>Main focus</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>BEM</td>
                    <td>naming clarity and explicit relationships</td>
                </tr>

                <tr>
                    <td>Tailwind</td>
                    <td>utility-first speed and design-token constraints</td>
                </tr>

                <tr>
                    <td>CSS Modules</td>
                    <td>component-level scoping through build tooling</td>
                </tr>

                <tr>
                    <td>@scope</td>
                    <td>native browser scoping for selector boundaries</td>
                </tr>

                <tr>
                    <td>LSCSS</td>
                    <td>layers, semantics, readability, maintainability</td>
                </tr>
            </tbody>
        </table>
    </section>

    <section id="how-to-use" class="content-block">
        <h2>
            How to use these comparisons
        </h2>

        <p>
            Use these pages when choosing a CSS approach, reviewing an existing
            codebase, or explaining why a familiar methodology may no longer be
            the best fit for a modern project.
        </p>
    </section>
</DocsLayout>
