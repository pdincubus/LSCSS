---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeExample from '../../components/CodeExample.astro';

const bemExample = `.product-card__title {
    margin: 0;
}

.product-card__price {
    color: var(--colour-accent);
}`;

const scopeExample = `@scope (.product-card) {
    .title {
        margin: 0;
    }

    .price {
        color: var(--colour-accent);
    }
}`;

const lscssExample = `@scope (.product-card) {
    .title {
        margin: 0;
    }
}

.product-card--featured {
    border-color: var(--colour-accent);
}

.is_active {
    opacity: 1;
}`;
---

<DocsLayout
    title="@scope vs BEM"
    description="Comparing CSS @scope and BEM-style architecture."
>
    <section class="site-hero">
        <p class="eyebrow">Comparisons</p>

        <h1>
            CSS @scope vs BEM
        </h1>

        <p class="intro">
            Modern CSS features are changing how component architecture works.
        </p>
    </section>

    <section class="content-block">
        <h2>
            Traditional BEM
        </h2>

        <CodeExample code={bemExample} />

        <p>
            BEM creates explicit relationships through naming.
        </p>
    </section>

    <section class="content-block">
        <h2>
            Scoped CSS
        </h2>

        <CodeExample code={scopeExample} />

        <p>
            Scope creates relationships through explicit scoping boundaries.
        </p>
    </section>

    <section class="content-block">
        <h2>
            Advantages of scope
        </h2>

        <ul>
            <li>shorter selectors</li>
            <li>improved readability</li>
            <li>reduced naming repetition</li>
            <li>clearer component boundaries</li>
            <li>lower specificity pressure</li>
        </ul>
    </section>

    <section class="content-block">
        <h2>
            Where BEM still helps
        </h2>

        <ul>
            <li>legacy browser support</li>
            <li>large established codebases</li>
            <li>teams with strong existing conventions</li>
            <li>projects without scope support</li>
        </ul>
    </section>

    <section class="content-block">
        <h2>
            LSCSS position
        </h2>

        <p>
            LSCSS treats scope as an evolution of shallow semantic selectors,
            not a replacement for architecture.
        </p>

        <CodeExample code={lscssExample} />
    </section>
</DocsLayout>
