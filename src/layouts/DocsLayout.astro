---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsPagination from '../components/DocsPagination.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

export interface Props {
    title?: string;
    description?: string;
    schemaType?: 'Article' | 'TechArticle' | 'WebPage';
    /** Override default OG image (`/images/og-default.svg`). Pass `""` to omit image meta tags. */
    ogImage?: string;
    noindex?: boolean;
    /**
     * Preload Space Mono 400. Defaults to true: every docs page renders code,
     * either as CodeExample blocks or inline `<code>` runs.
     */
    preloadMono?: boolean;
}

const {
    title,
    description,
    schemaType = 'WebPage',
    ogImage,
    noindex,
    preloadMono = true
} = Astro.props;
---

<BaseLayout
    title={title}
    description={description}
    schemaType={schemaType}
    ogImage={ogImage}
    noindex={noindex}
    preloadMono={preloadMono}
>
    <slot name="head" slot="head" />

    <main class="page-shell docs-layout">
        <DocsSidebar />

        <div class="docs-content">
            <Breadcrumbs />
            <slot />
            <RelatedLinks />
            <DocsPagination />
        </div>
    </main>
</BaseLayout>
