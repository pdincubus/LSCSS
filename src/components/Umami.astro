---
const websiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID?.trim();
const scriptUrl =
    import.meta.env.PUBLIC_UMAMI_SCRIPT_URL ?? 'https://cloud.umami.is/script.js';

/** Comma-separated hostnames; defaults to SITE hostname (plus www only for apex domains). */
function resolveDomains(): string | undefined {
    const override = import.meta.env.PUBLIC_UMAMI_DOMAINS?.trim();
    if (override) return override;

    if (!import.meta.env.SITE) return undefined;

    const hostname = new URL(import.meta.env.SITE).hostname;
    const labels = hostname.split('.');
    const isApex = labels.length === 2;

    if (hostname.startsWith('www.')) {
        return [hostname, hostname.slice(4)].join(',');
    }

    return isApex ? [hostname, `www.${hostname}`].join(',') : hostname;
}

const domains = resolveDomains();
---

{
    import.meta.env.PROD && websiteId && (
        <script
            defer
            src={scriptUrl}
            data-website-id={websiteId}
            data-do-not-track="true"
            data-domains={domains}
            data-exclude-search="true"
        />
    )
}
