---
const websiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID?.trim();
const scriptUrl =
    import.meta.env.PUBLIC_UMAMI_SCRIPT_URL ?? 'https://cloud.umami.is/script.js';
/** Where collect requests go. Must match Umami Cloud (script alone defaults to api-gateway.umami.dev). */
const hostUrl = import.meta.env.PUBLIC_UMAMI_HOST_URL ?? 'https://cloud.umami.is';
const respectDnt = import.meta.env.PUBLIC_UMAMI_RESPECT_DNT === 'true';
---

{
    import.meta.env.PROD && websiteId && (
        <script
            defer
            src={scriptUrl}
            data-website-id={websiteId}
            data-host-url={hostUrl}
            data-exclude-search="true"
            {...(respectDnt ? { 'data-do-not-track': 'true' } : {})}
        />
    )
}
