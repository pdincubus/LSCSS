---
import { docsNavigation } from '../data/docsNavigation';

const currentPath = Astro.url.pathname;
const currentIndex = docsNavigation.findIndex((item) => item.href === currentPath);

const previous = currentIndex > 0 ? docsNavigation[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < docsNavigation.length - 1
    ? docsNavigation[currentIndex + 1]
    : null;
---

{
    (previous || next) && (
        <nav class="doc-pager" aria-label="Documentation pagination">
            {
                previous ? (
                    <a class="link link--previous" href={previous.href} rel="prev">
                        <span class="arrow" aria-hidden="true">←</span>
                        <span class="body">
                            <span class="label">Previous</span>
                            <span class="name">{previous.label}</span>
                            <span class="context">{previous.section}</span>
                        </span>
                    </a>
                ) : (
                    <span class="spacer" aria-hidden="true"></span>
                )
            }

            {
                next ? (
                    <a class="link link--next" href={next.href} rel="next">
                        <span class="body">
                            <span class="label">Next</span>
                            <span class="name">{next.label}</span>
                            <span class="context">{next.section}</span>
                        </span>
                        <span class="arrow" aria-hidden="true">→</span>
                    </a>
                ) : (
                    <span class="spacer" aria-hidden="true"></span>
                )
            }
        </nav>
    )
}
