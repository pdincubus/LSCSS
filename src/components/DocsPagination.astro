---
import { docsNavigation } from '../data/docsNavigation';

const currentPath = Astro.url.pathname;
const currentIndex = docsNavigation.findIndex((item) => item.href === currentPath);

const previous = currentIndex > 0 ? docsNavigation[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < docsNavigation.length - 1
    ? docsNavigation[currentIndex + 1]
    : null;
---

{
    (previous || next) && (
        <nav class="docs-pagination" aria-label="Documentation pagination">
            {
                previous ? (
                    <a class="docs-pagination-link is-previous" href={previous.href}>
                        <span class="docs-pagination-label">Previous</span>
                        <strong>{previous.label}</strong>
                        <span class="docs-pagination-section">{previous.section}</span>
                    </a>
                ) : <span aria-hidden="true"></span>
            }

            {
                next ? (
                    <a class="docs-pagination-link is-next" href={next.href}>
                        <span class="docs-pagination-label">Next</span>
                        <strong>{next.label}</strong>
                        <span class="docs-pagination-section">{next.section}</span>
                    </a>
                ) : <span aria-hidden="true"></span>
            }
        </nav>
    )
}
