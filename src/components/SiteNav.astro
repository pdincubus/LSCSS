---
import { siteNavSections, type SiteNavSection, isSitePathCurrent } from '../data/nav';

const currentPath = Astro.url.pathname;

const isCurrent = (href: string) => isSitePathCurrent(currentPath, href);
const isInSection = (section: SiteNavSection) => {
    const paths = [section.href, ...section.links.map((link) => link.href)];
    return paths.some((path) => isCurrent(path));
};
---

<>
    <slot name="brand" />

    <button
        type="button"
        class="menu-toggle"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="site-nav-primary"
        aria-label="Menu"
    ></button>

    <nav class="site-nav" id="site-nav-primary" aria-label="Primary">
        <ul class="nav-list">
            {
                siteNavSections.map((section, index) => {
                    const subId = `site-nav-sub-${index}`;
                    const hasChildren = section.links.length > 0;

                    return (
                        <li class:list={['item', { is_current: isInSection(section) }]}>
                            {hasChildren ? (
                                <div class="row">
                                    <a href={section.href} aria-current={isCurrent(section.href) ? 'page' : undefined}>
                                        {section.label}
                                    </a>

                                    <button
                                        type="button"
                                        class="sub-toggle"
                                        data-sub-toggle
                                        aria-expanded="false"
                                        aria-controls={subId}
                                        aria-label={`${section.label} submenu`}
                                    ></button>
                                </div>
                            ) : (
                                <a href={section.href} aria-current={isCurrent(section.href) ? 'page' : undefined}>
                                    {section.label}
                                </a>
                            )}

                            {hasChildren && (
                                <ul id={subId}>
                                    {section.links.map((link) => (
                                        <li class:list={[{ is_nested: link.indent === true }]}>
                                            <a href={link.href} aria-current={isCurrent(link.href) ? 'page' : undefined}>
                                                {link.label}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            )}
                        </li>
                    );
                })
            }
        </ul>
    </nav>
</>

<script is:inline>
    (function () {
        const mobileNavQuery = window.matchMedia(
            '(width < 1280px), ((width >= 1280px) and (pointer: coarse))'
        );
        const header = document.querySelector('.site-header');
        const toggle = document.querySelector('[data-menu-toggle]');
        const nav = document.getElementById('site-nav-primary');

        if (!header || !(toggle instanceof HTMLButtonElement) || !nav) {
            return;
        }

        function isMobileNav() {
            return mobileNavQuery.matches;
        }

        function setOpen(open) {
            header.classList.toggle('is_nav_open', open);
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }

        function syncLayout() {
            if (isMobileNav()) {
                toggle.hidden = false;
            } else {
                toggle.hidden = true;
                setOpen(false);
            }
        }

        const subToggles = Array.from(nav.querySelectorAll('[data-sub-toggle]'));

        function closeAllSubs(except) {
            subToggles.forEach(function (btn) {
                if (btn === except) {
                    return;
                }
                btn.setAttribute('aria-expanded', 'false');
                const parent = btn.closest('li');
                if (parent) {
                    parent.classList.remove('is_open');
                }
            });
        }

        subToggles.forEach(function (btn) {
            btn.addEventListener('click', function () {
                if (!isMobileNav()) {
                    return;
                }
                const expanded = btn.getAttribute('aria-expanded') === 'true';
                closeAllSubs(expanded ? null : btn);
                btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
                const parent = btn.closest('li');
                if (parent) {
                    parent.classList.toggle('is_open', !expanded);
                }
            });
        });

        toggle.addEventListener('click', function () {
            if (!isMobileNav()) {
                return;
            }
            const willOpen = !header.classList.contains('is_nav_open');
            setOpen(willOpen);
            if (!willOpen) {
                closeAllSubs(null);
            }
        });

        nav.addEventListener('click', function (event) {
            if (!isMobileNav() || !header.classList.contains('is_nav_open')) {
                return;
            }
            const target = event.target;
            if (target instanceof HTMLAnchorElement) {
                closeAllSubs(null);
                setOpen(false);
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && header.classList.contains('is_nav_open')) {
                closeAllSubs(null);
                setOpen(false);
                toggle.focus();
            }
        });

        mobileNavQuery.addEventListener('change', function () {
            closeAllSubs(null);
            syncLayout();
        });
        syncLayout();
    })();
</script>
