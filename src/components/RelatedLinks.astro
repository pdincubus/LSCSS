---
import { docsNavigation } from '../data/docsNavigation';

const currentPath = Astro.url.pathname;
const currentPage = docsNavigation.find((item) => item.href === currentPath);

const related = currentPage
    ? docsNavigation
        .filter((item) => item.section === currentPage.section && item.href !== currentPath)
        .slice(0, 4)
    : [];
---

{
    related.length > 0 && (
        <aside class="related-links" aria-labelledby="related-links-heading">
            <h2 id="related-links-heading">
                Related pages
            </h2>

            <ul>
                {
                    related.map((item) => (
                        <li>
                            <a href={item.href}>
                                <span class="related-links__section">
                                    <span class="visually-hidden">Section: </span>
                                    {item.section}
                                </span>
                                <span class="related-links__label">{item.label}</span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </aside>
    )
}
