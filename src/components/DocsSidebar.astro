---
import { docsNavigation } from '../data/docsNavigation';

const currentPath = Astro.url.pathname;
const sectionNames = [...new Set(docsNavigation.map((item) => item.section))];
const sections = sectionNames.map((sectionName) => {
    return {
        title: sectionName,
        links: docsNavigation.filter((item) => item.section === sectionName)
    };
});

function isActive(href: string): boolean {
    if (href === '/') {
        return currentPath === '/';
    }

    return currentPath === href;
}
---

<aside class="docs-sidebar">
    <details class="docs-nav-disclosure">
        <summary>
            Documentation navigation
        </summary>

        <nav class="docs-nav" aria-label="Documentation">
            {
                sections.map((section) => (
                    <section class="docs-nav-section">
                        <h2 class="docs-nav-heading">
                            {section.title}
                        </h2>

                        <ul class="docs-nav-list">
                            {
                                section.links.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            aria-current={isActive(link.href) ? 'page' : undefined}
                                        >
                                            {link.label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </section>
                ))
            }
        </nav>
    </details>
</aside>
