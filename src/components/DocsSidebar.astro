---
import { docsNavigation, type DocsNavItem } from '../data/docsNavigation';

const currentPath = Astro.url.pathname;
const currentPage = docsNavigation.find((item) => item.href === currentPath);
const currentSection = currentPage?.section ?? 'Learn';
const links = docsNavigation.filter((item) => item.section === currentSection);
const topLevel = links.filter((item) => !item.parentHref);

function childrenOf(parentHref: string): DocsNavItem[] {
    return links.filter((item) => item.parentHref === parentHref);
}

function isActive(href: string): boolean {
    if (href === '/') {
        return currentPath === '/';
    }

    return currentPath === href;
}
---

<aside class="docs-sidebar">
    <details class="disclosure" data-doc-toc>
        <summary>
            {currentSection} navigation
        </summary>

        <nav class="toc" aria-label={`${currentSection} navigation`}>
            <section class="group">
                <h2 class="heading">
                    {currentSection}
                </h2>

                <ul class="list">
                    {
                        topLevel.map((link) => {
                            const children = childrenOf(link.href);

                            return (
                                <li>
                                    <a
                                        href={link.href}
                                        aria-current={isActive(link.href) ? 'page' : undefined}
                                    >
                                        {link.label}
                                    </a>
                                    {children.length > 0 && (
                                        <ul class="list list--nested">
                                            {children.map((child) => (
                                                <li>
                                                    <a
                                                        href={child.href}
                                                        aria-current={
                                                            isActive(child.href) ? 'page' : undefined
                                                        }
                                                    >
                                                        {child.label}
                                                    </a>
                                                </li>
                                            ))}
                                        </ul>
                                    )}
                                </li>
                            );
                        })
                    }
                </ul>
            </section>
        </nav>
    </details>
</aside>

<script>
    const details = document.querySelector('[data-doc-toc]');

    if (details instanceof HTMLDetailsElement) {
        const desktopQuery = window.matchMedia('(min-width: 1280px)');

        const syncDisclosureState = () => {
            details.open = desktopQuery.matches;
        };

        syncDisclosureState();
        desktopQuery.addEventListener('change', syncDisclosureState);
    }
</script>
