---
import { docsNavigation } from '../data/docsNavigation';

const currentPath = Astro.url.pathname;
const currentPage = docsNavigation.find((item) => item.href === currentPath);
const currentSection = currentPage?.section ?? 'Start here';
const links = docsNavigation.filter((item) => item.section === currentSection);

function isActive(href: string): boolean {
    if (href === '/') {
        return currentPath === '/';
    }

    return currentPath === href;
}
---

<aside class="docs-sidebar">
    <details class="docs-nav-disclosure">
        <summary>
            {currentSection} navigation
        </summary>

        <nav class="docs-nav" aria-label={`${currentSection} navigation`}>
            <section class="docs-nav-section">
                <h2 class="docs-nav-heading">
                    {currentSection}
                </h2>

                <ul class="docs-nav-list">
                    {
                        links.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    aria-current={isActive(link.href) ? 'page' : undefined}
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>

            <section class="docs-nav-section docs-nav-section--secondary">
                <h2 class="docs-nav-heading">
                    Other routes
                </h2>

                <ul class="docs-nav-list">
                    <li><a href="/learn/what-is-lscss/">Learn</a></li>
                    <li><a href="/apply/decision-trees/">Apply</a></li>
                    <li><a href="/teams/adoption/">Teams</a></li>
                    <li><a href="/writing/guides/">Writing</a></li>
                    <li><a href="/start/search/">Search</a></li>
                </ul>
            </section>
        </nav>
    </details>
</aside>
