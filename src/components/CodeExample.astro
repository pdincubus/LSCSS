---
export interface Props {
    code: string;
    language?: string;
    variant?: 'neutral' | 'before' | 'after';
}

const {
    code,
    language = 'css',
    variant = 'neutral'
} = Astro.props;

const variantLabels = {
    neutral: `${language.toUpperCase()} code example`,
    before: `Before, ${language.toUpperCase()} code example`,
    after: `After, ${language.toUpperCase()} code example`
};

const label = variantLabels[variant];
const languageClass = `language-${language}`;
/* `code` must stay plain text: Prism reads textContent and injects .token spans at runtime. */
---

<figure
    class:list={['code-example', `code-example--${variant}`]}
    data-code-example
    data-language={language}
    data-variant={variant}
>
    <figcaption>
        <span>{label}</span>

        <button class="copy-code-button" type="button" data-copy-code>
            Copy
        </button>
    </figcaption>

    <pre class={languageClass}><code class={languageClass}>{code}</code></pre>

    <p class="copy-code-status" data-copy-status aria-live="polite"></p>
</figure>
