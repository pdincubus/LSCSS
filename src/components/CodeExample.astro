---
export interface Props {
    code: string;
    language?: string;
}

const {
    code,
    language = 'css'
} = Astro.props;

const label = `${language.toUpperCase()} code example`;
---

<figure class="code-example" data-code-example data-language={language}>
    <figcaption>
        <span>{label}</span>

        <button class="copy-code-button" type="button" data-copy-code>
            Copy
        </button>
    </figcaption>

    <pre><code>{code}</code></pre>

    <p class="copy-code-status" data-copy-status aria-live="polite"></p>
</figure>

<script type="module" src="/scripts/code-example.js"></script>
