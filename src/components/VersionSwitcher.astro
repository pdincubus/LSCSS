---
import { currentVersion, versions } from '../data/versions';
---

<div class="version-switcher">
    <label for="version-select">
        Version
    </label>

    <select id="version-select" class="version-select">
        {
            versions.map((version) => (
                <option
                    value={version.href}
                    selected={version.version === currentVersion}
                >
                    {version.label} ({version.status})
                </option>
            ))
        }
    </select>
</div>

<script>
    const select = document.querySelector('.version-select');

    if (select) {
        select.addEventListener('change', (event) => {
            const target = event.target as HTMLSelectElement | null;
            if (target) {
                window.location.href = target.value;
            }
        });
    }
</script>
