---
import { siteNavSections, isSitePathCurrent } from '../data/nav';

const currentPath = Astro.url.pathname;

const isCurrent = (href: string) => isSitePathCurrent(currentPath, href);

const year = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="page-shell inner">
        <div class="intro">
            <p class="title">
                LSCSS
            </p>

            <p>
                Layered Semantic CSS. A practical methodology for calm,
                maintainable front-end architecture.
            </p>

            <p class="meta">
                Evolves with real delivery. Change what does not fit your codebase.
            </p>
        </div>

        <nav class="topics" aria-label="Documentation">
            {
                siteNavSections.map((section) => (
                    <a
                        href={section.href}
                        aria-current={isCurrent(section.href) ? 'page' : undefined}
                    >
                        {section.label}
                    </a>
                ))
            }
        </nav>

        <div class="bottom">
            <nav class="legal" aria-label="Site information">
                <p class="copyright">
                    © {year} LSCSS
                </p>

                <ul class="legal-list">
                    <li>
                        <a href="/accessibility/">Accessibility statement</a>
                    </li>
                    <li>
                        <a href="/ai/">AI and this site</a>
                    </li>
                    <li>
                        <a href="/versions/">Versions</a>
                    </li>
                    <li>
                        <a href="/rss.xml">RSS feed</a>
                    </li>
                    <li>
                        <a href="/sitemap-index.xml">Sitemap</a>
                    </li>
                </ul>
            </nav>

            <p class="credits">
                Built by <a href="https://crayonsandco.de/">Crayons and Code</a>.
            </p>
        </div>
    </div>
</footer>
