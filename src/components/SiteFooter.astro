---
import { siteNavSections, isSitePathCurrent } from '../data/nav';

const currentPath = Astro.url.pathname;

const isCurrent = (href: string) => isSitePathCurrent(currentPath, href);

const year = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="page-shell inner">
        <div class="intro">
            <p class="title">
                LSCSS
            </p>

            <p>
                LSCSS is Layered Semantic CSS: cascade layers, clear naming, modifiers and
                state classes, and a bounded theme layer—so large stylesheets stay navigable.
            </p>

            <nav class="topics" aria-label="Documentation">
                {
                    siteNavSections.map((section) => (
                        <a
                            href={section.href}
                            aria-current={isCurrent(section.href) ? 'page' : undefined}
                        >
                            {section.label}
                        </a>
                    ))
                }
            </nav>
        </div>

        <div class="bottom">
            <nav class="legal" aria-label="Site information">
                <p class="copyright">
                    © {year} LSCSS
                </p>

                <ul class="legal-list">
                    <li>
                        <a href="/accessibility/">Accessibility</a>
                    </li>
                    <li>
                        <a href="/privacy/">Privacy</a>
                    </li>
                    <li>
                        <a href="/cookies/">Cookies</a>
                    </li>
                    <li>
                        <a href="/ai/">AI and this site</a>
                    </li>
                    <li>
                        <a href="/versions/">Versions</a>
                    </li>
                    <li>
                        <a href="/rss.xml">RSS feed</a>
                    </li>
                    <li>
                        <a href="/sitemap.xml">Sitemap</a>
                    </li>
                    <li>
                        <a href="/llms.txt">llms.txt</a>
                    </li>
                </ul>
            </nav>

            <p class="credits">
                Methodology: <a href="https://crayonsandco.de/">Crayons and Code</a>.
                Documentation: AI-assisted, human-reviewed.
            </p>
        </div>
    </div>
</footer>
