---
interface Props {
    steps: string[];
}

const { steps } = Astro.props;
---

<ol class="migration-steps" aria-label="Recommended migration steps">
    {
        steps.map((step, index) => (
            <li class="step">
                <span class="marker" aria-hidden="true">
                    <span class="number">{index + 1}</span>
                </span>
                <p class="text">{step}</p>
            </li>
        ))
    }
</ol>
