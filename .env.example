# Umami Cloud — create a site at https://cloud.umami.is and paste the Website ID
PUBLIC_UMAMI_WEBSITE_ID=

# Collect endpoint (defaults to cloud.umami.is; do not omit — script.js alone posts to api-gateway.umami.dev)
# PUBLIC_UMAMI_HOST_URL=https://cloud.umami.is

# Optional: set to true to skip tracking when the browser has Do Not Track enabled
# PUBLIC_UMAMI_RESPECT_DNT=true

# Optional override (defaults to Umami Cloud)
# PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
